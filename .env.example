# Copy this file to .env and fill in real values. .env is gitignored and
# must never be committed — see Firebase Console > Project Settings for
# these values, and Google AI Studio for the Gemini key.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_GEMINI_API_KEY=

# Client-side key used to AES-encrypt stall merchant passwords before they are
# stored in Firestore. See src/utils/crypto.ts for the important caveat that
# this does not provide real secrecy in a backend-less SPA.
VITE_STALL_SECRET_KEY=

# Platform admin login. NEVER put a plaintext password here — only the SHA-256
# digest. Generate one with:  npm run hash:password "your-strong-password"
VITE_ADMIN_USERNAME=admin
VITE_ADMIN_PASSWORD_HASH=
