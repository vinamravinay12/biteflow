rules_version = '2';

// BiteFlow Firestore security rules.
//
// Auth model: every client establishes a real Firebase Auth session before it
// touches Firestore (see src/utils/firebase.ts `ensureFirebaseAuth`). The
// platform admin, stall merchants, and guests browsing before they register are
// signed in ANONYMOUSLY; registered customers upgrade to an email/password
// identity whose uid becomes their data namespace. Consequently:
//   * NO unauthenticated access is allowed anywhere — the wide-open
//     `allow read, write: if true` default is gone.
//   * Every write is shape-, type-, bound-, and size-validated so the store
//     cannot be flooded with malformed or oversized documents.
//   * Wallets can only be read/written by an authenticated session, hold a
//     validated non-negative balance, and can never be deleted.
//
// Why writes are gated on "authenticated + valid" rather than strict per-uid
// ownership: in this backend-less SPA, actors legitimately touch data they do
// not own by uid — the single admin manages every stall/menu, a merchant updates
// order copies keyed by kiosk id, and (critically) a merchant issues a wallet
// REFUND directly to a customer's wallet when it declines an order. A trusted
// backend minting per-role custom claims (or Cloud Functions performing refunds
// server-side) is required to tighten these to true per-uid ownership; that is
// the documented production hardening step, out of scope for this demo.
//
// Production hardening (documented, out of scope for this demo): mint custom
// claims (admin / foodkiosk / customer) from a trusted backend and gate each
// collection's writes on the caller's role instead of merely on being signed in.

service cloud.firestore {
  match /databases/{database}/documents {

    // ---- helpers -------------------------------------------------------
    function isAuthed() {
      return request.auth != null;
    }
    function isString(v, max) {
      return v is string && v.size() <= max;
    }
    function reasonableSize() {
      // Reject anything larger than a normal app document (~64 KB).
      return request.resource.size() < 65536;
    }
    function validUser() {
      let d = request.resource.data;
      return isString(d.uid, 128)
        && isString(d.email, 256)
        && isString(d.displayName, 256)
        && d.role in ['admin', 'foodkiosk', 'customer'];
    }
    function validStall() {
      let d = request.resource.data;
      return isString(d.name, 128)
        && isString(d.ownerUsername, 128)
        && isString(d.ownerPasswordEnc, 1024)   // AES-GCM base64 blob, never plaintext
        && d.active is bool;
    }
    function validMenuItem() {
      let d = request.resource.data;
      return isString(d.name, 256)
        && d.price is number && d.price >= 0 && d.price < 1000000
        && isString(d.stallId, 128)
        && d.isAvailable is bool;
    }
    function validOrder() {
      let d = request.resource.data;
      return isString(d.id, 128)
        && isString(d.customerUid, 128)
        && d.totalAmount is number && d.totalAmount >= 0
        && d.kioskIds is list;
    }

    // ---- user profiles -------------------------------------------------
    match /users/{uid} {
      // Profiles hold only display name / email / role. Readable by any signed-in
      // session; writable by any signed-in session (the admin seeds and manages
      // kiosk profiles it does not own by uid) provided the shape is valid.
      allow read: if isAuthed();
      allow write: if isAuthed() && reasonableSize() && validUser();

      // stalls owned by the single platform admin (managed via admin console)
      match /stalls/{stallId} {
        allow read: if isAuthed();
        allow create, update: if isAuthed() && reasonableSize() && validStall();
        allow delete: if isAuthed();
      }

      // per-kiosk menu items (managed by stall merchants)
      match /menu_items/{itemId} {
        allow read: if isAuthed();
        allow create, update: if isAuthed() && reasonableSize() && validMenuItem();
        allow delete: if isAuthed();
      }

      // per-customer and per-kiosk order copies. A merchant reads/updates the
      // kiosk copy (path keyed by kiosk id, not their auth uid), so this is
      // gated on being authenticated + valid rather than on uid ownership.
      match /orders/{orderId} {
        allow read: if isAuthed();
        allow create, update: if isAuthed() && reasonableSize() && validOrder();
        allow delete: if isAuthed();
      }

      // single wallet document per customer. Readable/writable only by an
      // authenticated session (a merchant must refund into it on decline — see
      // header), balance must be a valid non-negative number, and it can never
      // be deleted.
      match /wallet/{walletId} {
        allow read: if isAuthed();
        allow write: if isAuthed() && reasonableSize()
          && request.resource.data.balance is number
          && request.resource.data.balance >= 0;
        allow delete: if false;
      }
    }

    // ---- collection-group queries --------------------------------------
    // A nested `match /users/{uid}/orders/{orderId}` rule does NOT authorize a
    // collectionGroup() query — Firestore requires an explicit `/{path=**}/`
    // rule. Menu items form the public catalogue (no personal data), so browsing
    // them across every stall is safe to allow for any signed-in session.
    match /{path=**}/menu_items/{itemId} {
      allow read: if isAuthed();
    }

    // DELIBERATELY ABSENT: a `/{path=**}/orders/{orderId}` collection-group rule.
    // Granting it would let ANY signed-in session (including an anonymous guest)
    // enumerate every customer's orders — names, seat numbers, and totals. That
    // is a privacy leak, so cross-customer order enumeration is denied outright.
    // Consequence: the admin console's platform-wide order count cannot be
    // computed client-side and falls back to locally-known orders. Restoring it
    // properly requires role-based custom claims minted by a trusted backend
    // (or an aggregate maintained server-side) — see SECURITY.md.
    // Per-customer and per-kiosk order access still works via the nested paths.

    // ---- match fixtures (shared, admin-managed) ------------------------
    match /matches/{matchId} {
      allow read: if isAuthed();
      allow create, update: if isAuthed() && reasonableSize()
        && isString(request.resource.data.name, 256)
        && isString(request.resource.data.city, 128);
      allow delete: if isAuthed();
    }

    // ---- everything else is denied ------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
